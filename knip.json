{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.{ts,js}"],
      "project": ["scripts/**/*.{ts,js}"]
    },
    "apps/portal": {
      "entry": [
        "plugins/rust-telemetry-engine/index.tsx"
      ],
      "project": [
        "app/**/*.{ts,tsx}",
        "components/**/*.{ts,tsx}",
        "features/**/*.{ts,tsx}",
        "hooks/**/*.{ts,tsx}",
        "lib/**/*.{ts,tsx}",
        "plugins/**/*.{ts,tsx}"
      ]
    },
    "apps/cms": {
      "project": ["app/**/*.{ts,tsx}"]
    },
    "apps/overview": {
      "project": [
        "app/**/*.{ts,tsx}",
        "components/**/*.{ts,tsx}",
        "lib/**/*.{ts,tsx}"
      ]
    },
    "packages/theme": {
      "entry": ["src/tokens/*.ts", "src/react/*.tsx"],
      "project": ["src/**/*.{ts,tsx,css}"]
    },
    "packages/database": {
      "project": ["migrations/**/*.sql", "rls/**/*.ts"]
    },
    "packages/eslint-config": {
      "entry": ["*.js"],
      "project": ["*.js"]
    },
    "packages/supabase": {
      "entry": ["config.toml"],
      "project": ["src/**/*.ts"]
    },
    "packages/errors": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/hooks": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/types": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/typescript-config": {
      "entry": ["*.json"],
      "project": ["*.json"]
    },
    "packages/utils": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "entry": ["src/**/*.tsx"],
      "project": ["src/**/*.{ts,tsx,css}"]
    },
    "packages/redis": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/eval": {
      "entry": ["tests/**/*.py"],
      "project": ["**/*.{py,toml}"]
    }
  },
  "rules": {
    "files": "warn",
    "dependencies": "warn",
    "devDependencies": "warn",
    "unlisted": "warn",
    "binaries": "warn",
    "exports": "warn",
    "nsExports": "warn",
    "types": "warn",
    "nsTypes": "warn"
  }
}

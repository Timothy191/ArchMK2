{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "apps/*/app/layout.tsx",
    "apps/*/app/**/page.tsx",
    "apps/*/app/api/**/route.ts",
    "apps/*/src/index.ts",
    "packages/*/src/index.ts",
    "packages/*/src/server.ts",
    "packages/*/src/client.ts",
    "apps/cms/payload.config.ts"
  ],
  "project": [
    "apps/*/app/**/*.{ts,tsx}",
    "apps/*/src/**/*.{ts,tsx}",
    "apps/*/components/**/*.{ts,tsx}",
    "apps/*/features/**/*.{ts,tsx}",
    "apps/*/hooks/**/*.{ts,tsx}",
    "apps/*/lib/**/*.{ts,tsx}",
    "apps/*/plugins/**/*.{ts,tsx}",
    "packages/*/src/**/*.{ts,tsx}",
    "scripts/**/*.{ts,js}"
  ],
  "workspaces": {
    "apps/portal": {
      "entry": [
        "app/layout.tsx",
        "app/(hub)/page.tsx",
        "app/**/page.tsx",
        "app/api/**/route.ts",
        "middleware.ts",
        "instrumentation.ts"
      ]
    },
    "apps/cms": {
      "entry": [
        "app/(payload)/layout.tsx",
        "payload.config.ts",
        "next.config.mjs"
      ]
    },
    "apps/overview": {
      "entry": [
        "app/layout.tsx",
        "app/page.tsx"
      ]
    },
    "packages/theme": {
      "entry": [
        "src/tokens/*.ts",
        "src/react/*.tsx",
        "src/css/*.css",
        "src/tailwind/preset.ts"
      ]
    },
    "packages/ui": {
      "entry": [
        "src/index.ts"
      ]
    }
  },
  "rules": {
    "files": "warn",
    "dependencies": "warn",
    "devDependencies": "warn",
    "unlisted": "warn",
    "binaries": "warn",
    "exports": "warn",
    "nsExports": "warn",
    "types": "warn",
    "nsTypes": "warn"
  }
}

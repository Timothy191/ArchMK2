{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "VERCEL_ENV",
    "CI",
    "TURBO_TELEMETRY_DISABLED",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "INNGEST_EVENT_KEY",
    "NOVU_API_KEY",
    "OTEL_SERVICE_NAME",
    "PORTAL_VERSION",
    "RATE_LIMIT_IP_WHITELIST"
  ],
  "globalPassThroughEnv": [
    "HOME",
    "TMPDIR",
    "TMP",
    "SHELL",
    "PWD",
    "GITHUB_TOKEN",
    "GITHUB_SHA",
    "GITHUB_REF",
    "GITHUB_HEAD_REF"
  ],
  "globalDependencies": [
    "turbo.json",
    "tsconfig.json",
    "pnpm-workspace.yaml",
    ".npmrc"
  ],
  "tasks": {
    "codegen": {
      "dependsOn": [],
      "inputs": ["src/css/variables.css", "scripts/generate-tokens.mjs"],
      "outputs": ["src/tokens/generated.ts"]
    },
    "lint:tokens": {
      "dependsOn": [],
      "inputs": [
        "src/css/variables.css",
        "src/tailwind/preset.ts",
        "scripts/validate-tokens.mjs"
      ],
      "cache": true,
      "outputs": []
    },
    "lint:css": {
      "dependsOn": [],
      "inputs": ["src/**/*.css", ".stylelintrc.*"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build", "^codegen"],
      "env": [
        "NEXT_PUBLIC_*",
        "SUPABASE_*",
        "DATABASE_URL",
        "NEXT_RUNTIME",
        "SENTRY_DSN",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "TURBO_SUMMARIZE",
        "SKIP_TYPE_CHECK",
        "ENABLE_HEAVY_PLUGINS"
      ],
      "passThroughEnv": ["ANALYZE"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/*.test.ts",
        "!**/*.test.tsx",
        "!**/*.spec.ts",
        "!**/*.spec.tsx",
        "!**/__tests__/**",
        "!**/*.stories.tsx"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "outputLogs": "new-only"
    },
    "db:pull": {
      "cache": false,
      "passThroughEnv": ["SUPABASE_SERVICE_KEY"],
      "outputs": ["packages/supabase/migrations/**"]
    },
    "type-check": {
      "dependsOn": [],
      "env": ["NEXT_PUBLIC_*"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/tsconfig.json",
        "!**/*.test.ts",
        "!**/*.test.tsx",
        "!**/*.md",
        "!**/*.stories.*"
      ],
      "outputs": ["**/*.tsbuildinfo"],
      "outputLogs": "new-only"
    },
    "lint": {
      "dependsOn": [],
      "env": [
        "REDIS_URL",
        "NEXT_RUNTIME",
        "SENTRY_DSN",
        "ALLOWED_SCANNER_SOURCES",
        "OPENAI_API_KEY",
        "TOGETHER_API_KEY",
        "DATABASE_POOLER_URL",
        "INTERNAL_API_SECRET"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/tsconfig.json",
        ".eslintrc.*",
        "!pnpm-lock.yaml",
        "!**/*.test.ts",
        "!**/*.test.tsx",
        "!**/*.md",
        "!**/*.stories.*",
        "!**/__fixtures__/**"
      ],
      "outputs": ["node_modules/.cache/.eslintcache"],
      "outputLogs": "new-only"
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "NEXT_PUBLIC_*",
        "N8N_URL",
        "FLOWISE_URL",
        "PAYLOAD_SECRET",
        "PORT"
      ]
    },
    "test": {
      "dependsOn": [],
      "env": ["NEXT_PUBLIC_*", "SUPABASE_*", "NEXT_RUNTIME", "SENTRY_DSN"],
      "passThroughEnv": ["TEST_DB_URL", "MOCK_SERVER_PORT"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "jest.config.*",
        "vitest.config.*",
        "playwright.config.*",
        "!**/*.md",
        "!**/*.stories.*"
      ],
      "outputs": ["coverage/**/*"],
      "outputLogs": "new-only"
    },
    "clean": {
      "cache": false
    },
    "//#lint-root": {
      "inputs": ["!pnpm-lock.yaml", "*.ts", "*.tsx", "*.js", "*.json"]
    },
    "//#format-check": {
      "cache": true,
      "outputs": []
    },
    "//#quality": {
      "dependsOn": ["//#lint-root", "//#format-check"],
      "cache": true,
      "outputs": [],
      "outputLogs": "new-only"
    },
    "//#syncpack": {
      "inputs": [".syncpackrc.js", "**/package.json"]
    },
    "//#knip": {
      "inputs": ["knip.json", "**/package.json", "**/tsconfig.json"],
      "cache": true
    }
  }
}

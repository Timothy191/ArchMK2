{
  "name": "arch-systems",
  "version": "1.5.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "bash scripts/dev.sh",
    "ensure-reachability": "python3 scripts/ensure_reachability.py",
    "lint": "nx run-many -t lint",
    "lint:root": "eslint . --max-warnings 0 --ignore-pattern apps --ignore-pattern packages --no-error-on-unmatched-pattern",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "quality": "nx run-many -t lint type-check test lint:tokens lint:css && pnpm lint:root && pnpm format:check && pnpm deps:lint && pnpm knip",
    "syncpack": "syncpack lint",
    "ui": "pnpm --filter @repo/ui ui",
    "test": "nx run-many -t test",
    "type-check": "nx run-many -t type-check",
    "test:e2e": "playwright test",
    "deps:check": "syncpack list-mismatches",
    "deps:fix": "syncpack fix-mismatches",
    "deps:lint": "syncpack lint",
    "knip": "knip --no-config-hints",
    "knip:fix": "knip --fix --no-config-hints",
    "analyze": "ANALYZE=true pnpm --filter portal build",
    "md:lint": "markdownlint \"**/*.md\" --ignore node_modules --ignore .turbo --ignore '**/node_modules' --ignore '**/.next' --ignore '**/dist'",
    "md:fix": "markdownlint \"**/*.md\" --fix --ignore node_modules --ignore .turbo --ignore '**/node_modules' --ignore '**/.next' --ignore '**/dist'",
    "commitlint": "commitlint --edit",
    "deploy": "bash scripts/deploy.sh",
    "deploy:local": "bash scripts/deploy.sh local",
    "deploy:staging": "bash scripts/deploy.sh staging",
    "deploy:production": "bash scripts/deploy.sh production",
    "deploy:rollback": "bash scripts/deploy.sh production --rollback",
    "fresh-start": "bash scripts/deploy.sh local --clean",
    "deploy:dev": "bash scripts/deploy-dev.sh",
    "monitor": "bash scripts/monitor-hud.sh",
    "monitor:grafana": "docker compose -f docker-compose.monitoring.yml up -d",
    "monitor:grafana-stop": "docker compose -f docker-compose.monitoring.yml down",
    "shutdown": "bash scripts/shutdown.sh",
    "db:docs": "bash scripts/generate-db-docs.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,mjs,yaml,yml}": "prettier --write",
    "*": "secretlint --secretlintrc .secretlintrc.json"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@playwright/test": "^1.60.0",
    "@repo/typescript-config": "workspace:*",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "eslint": "catalog:",
    "husky": "^9.1.7",
    "knip": "^5.45.0",
    "lint-staged": "^17.0.7",
    "markdownlint-cli": "^0.41.0",
    "nx": "22.7.5",
    "prettier": "catalog:",
    "secretlint": "^13.0.2",
    "supabase": "catalog:",
    "syncpack": "^13.0.4",
    "turbo": "^2.9.15"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "volta": {
    "node": "24.15.0",
    "pnpm": "9.15.9"
  }
}

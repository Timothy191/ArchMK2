{
  "name": "arch-systems",
  "version": "1.5.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo run dev --filter=portal",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "ui": "pnpm --filter @repo/ui ui",
    "test:e2e": "playwright test",
    "deploy:local": "bash scripts/deploy-local.sh",
    "fresh-start": "bash scripts/fresh-start.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": "eslint --fix"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "catalog:",
    "supabase": "^2.98.2",
    "turbo": "2.1.1"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.17.0"
  },
  "volta": {
    "node": "20.17.0",
    "pnpm": "9.12.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4"
  }
}

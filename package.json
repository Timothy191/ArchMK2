{
  "name": "arch-systems",
  "version": "1.5.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo run dev --filter=portal",
    "lint": "turbo lint",
    "lint:root": "eslint . --max-warnings 0 --ignore-pattern apps --ignore-pattern packages",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "quality": "turbo run //#quality && pnpm deps:lint && pnpm knip",
    "ui": "pnpm --filter @repo/ui ui",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "deps:check": "syncpack list-mismatches",
    "deps:fix": "syncpack fix-mismatches",
    "deps:lint": "syncpack lint",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "md:lint": "markdownlint \"**/*.md\" --ignore node_modules --ignore .turbo --ignore '**/node_modules' --ignore '**/.next' --ignore '**/dist'",
    "md:fix": "markdownlint \"**/*.md\" --fix --ignore node_modules --ignore .turbo --ignore '**/node_modules' --ignore '**/.next' --ignore '**/dist'",
    "size": "bundlesize",
    "deploy:local": "bash scripts/deploy-local.sh",
    "fresh-start": "bash scripts/deploy-local.sh --clean",
    "monitor": "bash scripts/monitor-hud.sh",
    "monitor:grafana": "docker compose -f docker-compose.monitoring.yml up -d",
    "monitor:grafana-stop": "docker compose -f docker-compose.monitoring.yml down",
    "shutdown": "bash scripts/shutdown.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": "eslint --fix"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/errors": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "catalog:",
    "supabase": "catalog:",
    "bundlesize": "^0.18.0",
    "knip": "^5.45.0",
    "markdownlint-cli": "^0.41.0",
    "syncpack": "^13.0.4",
    "turbo": "^2.9.14"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.17.0"
  },
  "volta": {
    "node": "20.17.0",
    "pnpm": "9.12.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4"
  }
}

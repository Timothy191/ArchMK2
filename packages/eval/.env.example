# DeepEval requires an OpenAI API key for LLM-based metrics
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Portal URL for live AI service tests (default: http://localhost:3000)
PORTAL_BASE_URL=http://localhost:3000

# Use cached golden responses when portal is unavailable (default: true)
EVAL_USE_CACHE=true
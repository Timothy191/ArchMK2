{
  "name": "@repo/supabase",
  "version": "1.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./client": "./src/client.ts",
    "./middleware": "./src/middleware.ts",
    "./read-replica": "./src/read-replica.ts",
    "./kysely": "./src/kysely.ts",
    "./service-role": "./src/service-role.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --cache --cache-location node_modules/.cache/.eslintcache --max-warnings 0",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "supabase:dev": "pnpx supabase start",
    "supabase:init": "pnpx supabase init",
    "supabase:link": "pnpx supabase link --project-ref <your-project-ID>",
    "supabase:pull": "pnpx supabase db pull",
    "supabase:push": "pnpx supabase db push"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "pg": "^8.13.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "catalog:",
    "kysely": "^0.27.6"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.11.10",
    "next": "^16.2.6",
    "typescript": "catalog:"
  }
}

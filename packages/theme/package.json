{
  "name": "@repo/theme",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "node sd.config.mjs && node scripts/generate-tokens.mjs",
    "build": "pnpm codegen",
    "dev": "node sd.config.mjs --watch",
    "lint": "eslint . --cache --cache-location node_modules/.cache/.eslintcache --max-warnings 0",
    "lint:tokens": "node scripts/validate-tokens.mjs",
    "lint:css": "stylelint 'src/css/**/*.css'",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "tokens:watch": "chokidar 'tokens.json' -c 'pnpm build'"
  },
  "exports": {
    ".": "./src/index.ts",
    "./css": "./src/css/index.css",
    "./tokens": "./src/tokens/index.ts",
    "./react": "./src/react/index.ts",
    "./tailwind": "./src/tailwind/preset.ts",
    "./motion": "./src/tokens/motion.ts"
  },
  "dependencies": {
    "lucide-react": "catalog:",
    "next-themes": "^0.4.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "chokidar-cli": "^3.0.0",
    "react": "catalog:react19",
    "style-dictionary": "^5.4.1",
    "stylelint": "^17.11.1",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "catalog:",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "^19"
  }
}

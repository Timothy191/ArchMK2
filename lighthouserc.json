{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/login",
        "http://localhost:3000/drilling",
        "http://localhost:3000/engineering",
        "http://localhost:3000/access-control",
        "http://localhost:3000/training"
      ],
      "numberOfRuns": 3,
      "settings": {
        "throttlingMethod": "simulate",
        "formFactor": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.8 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 2000 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 200 }],
        "interactive": ["warn", { "maxNumericValue": 3500 }],
        "offscreen-images": ["warn", { "maxNumericValue": 0 }],
        "uses-responsive-images": ["warn", { "maxNumericValue": 0 }],
        "unminified-javascript": ["error", { "maxNumericValue": 0 }],
        "unused-javascript": ["warn", { "maxNumericValue": 0 }]
      }
    }
  }
}

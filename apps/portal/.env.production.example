# ─────────────────────────────────────────────────────────────────
# Arch-Systems Portal — Production Environment Template
# Copy to .env and fill in all required values before deploying.
# NEVER commit this file with real secrets.
# ─────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────
# Replace <server-ip> with the on-premises server's LAN IP address.
NEXT_PUBLIC_SUPABASE_URL=http://<server-ip>:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_URL=http://<server-ip>:54321
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_KEY=<your-service-role-key>

# Read replica (optional — omit if not running docker-compose.replica.yml)
SUPABASE_READ_REPLICA_URL=http://<server-ip>:54322

# ── AI Providers ─────────────────────────────────────────────────
# At least one provider required for AI chat features.
GROQ_API_KEY=<your-groq-key>
OPENROUTER_API_KEY=<your-openrouter-key>
TOGETHER_API_KEY=<your-together-key>
OPENAI_API_KEY=<your-openai-key>

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://:<REDIS_PASSWORD>@localhost:6379
# Must match REDIS_PASSWORD in docker-compose.production.yml
REDIS_PASSWORD=<strong-random-password>

# ── External Tools ────────────────────────────────────────────────
N8N_URL=http://localhost:5678
N8N_USER=plantcor
N8N_PASSWORD=<strong-random-password>
N8N_ENCRYPTION_KEY=<32-char-random-hex>

FLOWISE_URL=http://localhost:3001
FLOWISE_USER=plantcor
FLOWISE_PASSWORD=<strong-random-password>
FLOWISE_SECRET_KEY=<32-char-random-hex>

# ── Monitoring ────────────────────────────────────────────────────
SENTRY_DSN=<your-sentry-dsn>

# ── Deployment Notifications (optional) ──────────────────────────
# If set, deploy-production.sh will POST to this URL on successful deploy.
# Create an n8n webhook trigger and paste the URL here.
DEPLOY_WEBHOOK_URL=http://localhost:5678/webhook/<your-webhook-id>

# ── Next.js ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
NEXTAUTH_URL=http://<server-ip>:3000
NEXTAUTH_SECRET=<32-char-random-hex>
